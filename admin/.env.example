# Copy to .env.local (Next.js convention) and fill in.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dedicated Sepolia RPC for browser on-chain reads (optional locally; required
# in production — the public RPC is rate-limited). Can be domain-restricted.
NEXT_PUBLIC_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key

# Deployed contract addresses (Sepolia) — kept for parity with the user frontend
NEXT_PUBLIC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STAKING_ADDRESS=0x0000000000000000000000000000000000000000
