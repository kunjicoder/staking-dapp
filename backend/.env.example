# Port the Express server listens on
PORT=4000

# Sepolia JSON-RPC endpoint (Alchemy/Infura/public). Indexer + live reads use this.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployed contract addresses (Sepolia)
TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
STAKING_ADDRESS=0x0000000000000000000000000000000000000000

# Block the contracts were deployed at — indexer starts here on first run
DEPLOY_BLOCK=0

# Supabase project URL and SERVICE ROLE key (server-side only, never expose to a browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Secret used to sign JWTs — any long random string
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated wallet addresses that get role=admin on SIWE login
ADMIN_ADDRESSES=0x0000000000000000000000000000000000000000

# Comma-separated origins allowed by CORS (user frontend + admin app)
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001
